rules_version = '2';

// Reglas de seguridad de Firestore para CI Quality Group.
//
// Patrón de seguridad: cada usuario autenticado tiene un doc en
// /users/{uid} con un `role` (admin | sales | hours) y un flag `active`.
// Los helpers de abajo leen ese doc para autorizar cada operación.
//
// Para desplegar tras editar:
//   firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function role() {
      return userDoc().role;
    }

    function isActive() {
      return userDoc().get('active', true) == true;
    }

    function isAdmin() {
      return isSignedIn() && role() == 'admin' && isActive();
    }

    function isSales() {
      return isSignedIn() && role() == 'sales' && isActive();
    }

    function isHours() {
      return isSignedIn() && role() == 'hours' && isActive();
    }

    function isAuditor() {
      return isSignedIn() && role() == 'auditor' && isActive();
    }

    function isCajero() {
      return isSignedIn() && role() == 'cajero' && isActive();
    }

    // ---------- Users ----------
    // Cada usuario lee su propio perfil (necesario para arrancar la app
    // y resolver el rol). Admin lee y escribe todos los perfiles.
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    // ---------- Workers (trabajadores operativos) ----------
    // Todos los autenticados leen (el encargado de horas necesita la
    // lista). Solo admin crea/edita/desactiva.
    match /workers/{wid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ---------- Sales ----------
    // Admin, sales, cajero y auditor leen. Auditor: solo lectura (su
    // dashboard muestra ventas filtradas por su `auditFilter`; el
    // filtrado real lo hace la app cliente con .where()).
    //
    // - Admin: control total.
    // - Sales: crea solicitudes; solo puede editar las suyas mientras
    //   sigan en `generada` y estén dentro de la ventana de 24 h. No
    //   puede tocar campos financieros ni el state.
    // - Cajero: actualiza el workflow (state) y agregados de pago
    //   (paidAmount, lossAmount, etc.). No puede borrar.
    // Las validaciones detalladas de "qué campo puede tocar qué rol"
    // se hacen en cliente; las rules dejan el guard rail grueso para
    // que el rol incorrecto no pueda escribir nunca.
    match /sales/{sid} {
      allow read: if isAdmin() || isSales() || isCajero() || isAuditor();
      allow create: if isAdmin() || isSales();
      allow update: if isAdmin()
        || isCajero()
        || (isSales()
            && resource.data.createdBy == request.auth.uid
            && resource.data.get('state', 'procesada') == 'generada'
            && resource.data.get('editableUntil', request.time) > request.time);
      allow delete: if isAdmin();

      // ---------- Payments (subcolección) ----------
      // Solo admin y cajero ven y registran abonos. Solo admin puede
      // borrar (anular un pago se modela como delete + recalculo del
      // padre en una transacción).
      match /payments/{pid} {
        allow read: if isAdmin() || isCajero();
        allow create: if (isAdmin() || isCajero())
          && request.resource.data.amount is number
          && request.resource.data.amount > 0;
        allow update: if false;
        allow delete: if isAdmin();
      }
    }

    // ---------- Hours entries ----------
    // Hours y admin pueden leer y registrar horas. Solo admin borra.
    match /hours_entries/{hid} {
      allow read: if isAdmin() || isHours();
      allow create, update: if isAdmin() || isHours();
      allow delete: if isAdmin();
    }

    // ---------- Master lists ----------
    // Todos los autenticados leen (dropdowns en sales y workers).
    // Admin tiene control total (create/update/delete sin restricciones).
    // Sales y hours solo pueden CREAR items como sugerencias
    // (`userSuggested == true`); el admin las aprueba después editándolas
    // o las puede borrar.
    match /master_lists/{listId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      match /items/{itemId} {
        allow read: if isSignedIn();
        allow create: if isAdmin()
          || (isSignedIn()
              && request.resource.data.get('userSuggested', false) == true);
        allow update, delete: if isAdmin();
      }
    }

    // ---------- Counters (consecutivo CQG-XXX) ----------
    // Solo sales y admin pueden incrementar. La transacción atómica
    // de ventas necesita escribir aquí.
    match /counters/{cid} {
      allow read, write: if isAdmin() || isSales();
    }

    // ---------- Settings (jornada laboral) ----------
    // Lectura para todos los autenticados (el calculador de horas y
    // varias pantallas leen la jornada). Escritura solo admin.
    match /settings/{sid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ---------- Form schemas (constructor de formularios) ----------
    // Lectura para todos los autenticados (el renderer del form de
    // ventas necesita el schema). Escritura solo admin.
    match /form_schemas/{module} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ---------- Notifications (bell in-app) ----------
    // Colección plana de notifs con target por uid y/o por rol. Firestore
    // no permite OR en `where`, así que cada cliente hace dos queries
    // paralelas y mergea. Los repos de sales y cashier las escriben en
    // la misma transacción que produce el evento.
    //
    // - Lee/actualiza: solo si la notif te apunta (por uid o por rol).
    //   El update está limitado a tocar SOLO el array `readBy` para que
    //   un usuario pueda marcarla como leída pero no editar el contenido.
    // - Crea: cualquier autenticado, siempre que `createdBy == uid` (la
    //   regla evita que alguien suplante el actor). Limita el spam a las
    //   acciones reales que el código emite.
    // - Borra: solo admin (cleanup manual; no hay TTL).
    match /notifications/{id} {
      function isTargetUser() {
        return isSignedIn()
            && (request.auth.uid in resource.data.get('targetUids', [])
                || role() in resource.data.get('targetRoles', []));
      }
      allow read: if isTargetUser();
      allow create: if isSignedIn()
                    && request.resource.data.createdBy == request.auth.uid;
      allow update: if isTargetUser()
                    && request.resource.data.diff(resource.data)
                        .affectedKeys().hasOnly(['readBy']);
      allow delete: if isAdmin();
    }

  }
}
